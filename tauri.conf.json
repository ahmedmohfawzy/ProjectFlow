{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjectFlow",
  "version": "1.0.0",
  "identifier": "com.ahmedfawzy.projectflow",
  "build": {
    "frontendDist": ".",
    "devUrl": "http://localhost:3456",
    "beforeDevCommand": "node server.js",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title":            "ProjectFlow™",
        "width":            1280,
        "height":           800,
        "minWidth":         900,
        "minHeight":        600,
        "resizable":        true,
        "fullscreen":       false,
        "decorations":      true,
        "transparent":      false,
        "center":           true,
        "fileDropEnabled":  true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon-192.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "ProjectFlow"
    }
  },
  "bundle": {
    "active":       true,
    "targets":      "all",
    "icon":         ["icons/icon-192.png", "icons/icon-512.png"],
    "resources":    [],
    "externalBin":  [],
    "copyright":    "© 2026 Ahmed M. Fawzy",
    "category":     "Productivity",
    "shortDescription": "Professional browser-based Project Management",
    "longDescription": "ProjectFlow™ — Gantt charts, EVM, Portfolio management, Multi-project support",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": { "depends": [] },
      "rpm": { "depends": [] },
      "appimage": { "bundleMediaFramework": true }
    }
  },
  "plugins": {
    "shell": { "open": true },
    "fs":    { "scope": { "allow": [{ "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }] } },
    "dialog": {},
    "notification": { "all": true }
  }
}
